<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.InfiniteZoomDrawing" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/toolbar_bg</item>
        <item name="colorPrimaryVariant">#1565C0</item>
        <item name="colorOnPrimary">@android:color/white</item>
        <item name="colorSecondary">#FF9800</item>
        <item name="colorOnSecondary">@android:color/black</item>
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
    </style>

    <style name="ColorSwatch">
        <item name="android:layout_width">26dp</item>
        <item name="android:layout_height">26dp</item>
        <item name="android:layout_margin">3dp</item>
        <item name="android:background">@drawable/color_swatch_border</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
    </style>
</resources>
